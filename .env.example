PORT=8080

# System config: database
DB_HOST=localhost
DB_PORT=5432
DB_USER=streaming
DB_PASSWORD=streaming
DB_NAME=streaming
DB_SSLMODE=disable

# System config: cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional override; when provided it takes precedence over DB_* fields.
# DATABASE_URL=postgres://streaming:streaming@localhost:5432/streaming?sslmode=disable

MIGRATIONS_DIR=migrations

# App config: auth/jwt settings
# Use a long random secret in real environments.
JWT_SECRET=change-me-to-a-strong-secret
JWT_ISSUER=demo-streaming
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# App config: dev/local media URLs
DEV_SRS_RTMP_BASE_URL=rtmp://localhost:1935/live
#
# Optional: when streamer client is on another machine, set publish host to LAN IP:
#   make local-ip
#   export IP=$(make local-ip)
#   DEV_SRS_RTMP_PUBLISH_BASE_URL=rtmp://$IP:1935/live
DEV_SRS_RTMP_PUBLISH_BASE_URL=
#
# Playback origin (SRS) and CDN (nginx edge). API will prefer CDN base when present.
DEV_SRS_PLAYBACK_ORIGIN_BASE_URL=http://localhost:8081/live
DEV_SRS_PLAYBACK_CDN_BASE_URL=http://localhost:8088/live

# Internal HLS origin base URL (used by API to proxy/rewrite HLS by playback_id).
# In docker-compose network, SRS is reachable by service name `srs`.
SRS_INTERNAL_PLAYBACK_ORIGIN_BASE_URL=http://srs:8080/live

# SRS webhook protection (optional but recommended).
# When set, SRS must send this value in `X-SRS-Secret` header for callbacks.
SRS_WEBHOOK_SECRET=

# Transcode worker (enqueue on SRS on_publish, consume from Redis list).
# In docker compose, service `transcode` sets TRANSCODE_ENABLED=true via environment override.
TRANSCODE_ENABLED=false
TRANSCODE_QUEUE_KEY=transcode:publish_jobs
# Optional: ffmpeg input as RTMP (recommended in Docker: rtmp://srs:1935/live). When set, HLS base below is ignored for input.
TRANSCODE_INPUT_RTMP_BASE_URL=
TRANSCODE_INPUT_BASE_URL=http://srs:8080/live
# Only for HLS input: seconds to wait for first playlist 200 before starting ffmpeg.
TRANSCODE_INPUT_WAIT_MAX_SECONDS=90
TRANSCODE_OUTPUT_DIR=./tmp/transcode
TRANSCODE_FFMPEG_BIN=ffmpeg
TRANSCODE_PRESET=veryfast
