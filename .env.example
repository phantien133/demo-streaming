PORT=8080

# System config: database
DB_HOST=localhost
DB_PORT=5432
DB_USER=streaming
DB_PASSWORD=streaming
DB_NAME=streaming
DB_SSLMODE=disable

# System config: cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional override; when provided it takes precedence over DB_* fields.
# DATABASE_URL=postgres://streaming:streaming@localhost:5432/streaming?sslmode=disable

MIGRATIONS_DIR=migrations

# App config: auth/jwt settings
# Use a long random secret in real environments.
JWT_SECRET=change-me-to-a-strong-secret
JWT_ISSUER=demo-streaming
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
